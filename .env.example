# ===========================================
# ResumeAI Pro - Environment Variables
# ===========================================

# App
NODE_ENV=development
APP_PORT=3000
API_PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database (Isolated from OmniBuilder)
DATABASE_URL=postgresql://resumeai:resumeai123@localhost:5433/resumeai
REDIS_URL=redis://localhost:6380

# JWT
JWT_SECRET=resumeai-jwt-secret-change-in-production
JWT_REFRESH_SECRET=resumeai-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Encryption (for AI API keys)
ENCRYPTION_KEY=32-char-resumeai-encryption-key!

# Storage
UPLOAD_DIR=./uploads

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
