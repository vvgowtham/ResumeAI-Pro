{
  "name": "resumeai-pro",
  "version": "1.0.0",
  "private": true,
  "description": "AI Resume Builder & ATS Optimizer",
  "author": "Gowtham V V <vvgowthamfb@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @resumeai/database generate",
    "db:migrate": "pnpm --filter @resumeai/database migrate:dev",
    "db:push": "pnpm --filter @resumeai/database db:push",
    "db:seed": "pnpm --filter @resumeai/database seed",
    "db:studio": "pnpm --filter @resumeai/database studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["prettier --write"],
    "*.{json,css,md}": ["prettier --write"]
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
