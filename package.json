{
  "name": "resumeai-pro",
  "version": "1.0.0",
  "private": true,
  "description": "AI Resume Builder & ATS Optimizer",
  "author": "Gowtham V V <vvgowthamfb@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:migrate": "pnpm --filter @resumeai/database migrate:dev",
    "db:seed": "pnpm --filter @resumeai/database seed",
    "db:studio": "pnpm --filter @resumeai/database studio",
    "deploy:web": "pnpm --filter @resumeai/web deploy",
    "deploy:api": "pnpm --filter @resumeai/api deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,css,md}": ["prettier --write"]
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
