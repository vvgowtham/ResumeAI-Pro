generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  phone     String?
  location  String?
  linkedin  String?
  plan      Plan     @default(FREE)
  credits   Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes      Resume[]
  aiProviders  AiProvider[]
  downloads    Download[]
  atsReports   AtsReport[]
  coverLetters CoverLetter[]
  settings     UserSettings?

  @@map("users")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

model Resume {
  id         String       @id @default(cuid())
  userId     String
  title      String
  content    Json         @default("{}")
  templateId String?
  atsScore   Int          @default(0)
  status     ResumeStatus @default(DRAFT)
  pages      Int          @default(1)
  isFavorite Boolean      @default(false)
  isArchived Boolean      @default(false)
  tags       String[]     @default([])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]
  downloads Download[]
  atsReports AtsReport[]

  @@index([userId])
  @@map("resumes")
}

enum ResumeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ResumeVersion {
  id       String   @id @default(cuid())
  resumeId String
  version  Int
  content  Json     @default("{}")
  changes  String?
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("resume_versions")
}

model Template {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  category   TemplateCategory
  atsScore   Int              @default(90)
  thumbnail  String?
  colors     Json?            @default("{}")
  layout     Json             @default("{}")
  industries String[]         @default([])
  isPremium  Boolean          @default(false)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())

  @@map("templates")
}

enum TemplateCategory {
  ATS_FRIENDLY
  ATTRACTIVE
}

model AiProvider {
  id          String  @id @default(cuid())
  userId      String
  name        String
  provider    String
  apiKey      String
  baseUrl     String?
  model       String
  temperature Float   @default(0.7)
  maxTokens   Int     @default(4096)
  systemPrompt String?
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_providers")
}

model AtsReport {
  id           String @id @default(cuid())
  userId       String
  resumeId     String?
  fileName     String
  overallScore Int
  formatting   Int    @default(0)
  keywords     Int    @default(0)
  grammar      Int    @default(0)
  readability  Int    @default(0)
  sections     Int    @default(0)
  skills       Int    @default(0)
  experience   Int    @default(0)
  education    Int    @default(0)
  suggestions  Json   @default("[]")
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id])

  @@index([userId])
  @@map("ats_reports")
}

model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  jobTitle  String?
  company   String?
  tone      String   @default("professional")
  language  String   @default("english")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cover_letters")
}

model Download {
  id       String       @id @default(cuid())
  userId   String
  resumeId String?
  fileName String
  format   ExportFormat
  size     Int          @default(0)
  createdAt DateTime    @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id])

  @@index([userId])
  @@map("downloads")
}

enum ExportFormat {
  PDF
  DOCX
  HTML
  MARKDOWN
  TXT
  PNG
  JPG
  JSON
}

model UserSettings {
  id            String       @id @default(cuid())
  userId        String       @unique
  theme         String       @default("light")
  language      String       @default("en")
  notifications Boolean      @default(true)
  autoSave      Boolean      @default(true)
  defaultExport ExportFormat @default(PDF)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
